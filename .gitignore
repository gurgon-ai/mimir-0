*.db
*.db-shm
*.db-wal
*.db-journal
*.sqlite
*.sqlite3
data/
# The documents drop folder + the Library's composite pages — the user's own knowledge, never committed
documents/
library/

# Test / type-check / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Editors / OS
.idea/
