# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
*.egg

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment / secrets
.env
*.local

# Local deployment config (the committed template is mimir.toml.example)
/mimir.toml

# Logs (rotating server logs are runtime data, never committed)
*.log
*.log.*

# Databases / runtime data (the brain's state is never committed)
*.db
*.db-shm
*.db-wal
*.db-journal
*.sqlite
*.sqlite3
data/
# The documents drop folder + the Library's composite pages — ship the empty folders (so a fresh
# install has somewhere to drop files), but never commit the user's own knowledge inside them.
documents/*
!documents/.gitkeep
library/*
!library/.gitkeep

# Test / type-check / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Editors / OS
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# Local scratch — screenshots, scratch notes (never part of the public repo)
Screenshot*.png
*.local.md

# AI build-guide for local coding sessions — kept on disk, not published (carries provenance)
CLAUDE.md
