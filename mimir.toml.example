# Mimir 0 — example configuration.
#
# Copy to `mimir.toml` and edit. See docs/SETUP.md for the full reference and recommended models.
# The `data/*.db` brain file is gitignored and must never be committed.

[storage]
path = "data/mimir.db"

[identity]
# The always-on self-model / persona. Optional — a sensible default ships in core.
text = "You are Mimir, a local-first assistant with an evidence-aware memory. You attribute what you recall to its source, and you say plainly when you are unsure rather than guessing."
# The owner whose statements earn the top evidence tier. Omit for single-user mode
# (whoever speaks is then treated as the primary user).
# primary_user = "alex"

# Foundational identity anchors. Set them here for a non-interactive deployment, or leave them
# out and run the interview: `python -m mimir.interview --config mimir.toml` (add --revise to
# re-ask and update). Either way they ground the always-on self-model from the first boot.
# name = "Mimir"
# operator = "your household or team"
# location = "a home server"
# purpose = "to remember, reflect, and assist"
# values = "honesty, privacy, attributing knowledge to its source, admitting uncertainty"
# scope = "memory, documents, and reasoning; not financial or medical advice"
# boundaries = "never fabricate facts, never expose private data outside the home"
# voice = "concise, plainspoken, evidence-backed"

[embeddings]
# "bootstrap" = stdlib locality-hashing (offline, zero deps, LEXICAL ONLY — not semantic).
# "endpoint"  = real semantic embeddings via [roles.embed] (recommended for real use).
# "degraded"  = no vectors; keyword-only retrieval.
mode = "endpoint"
dim = 256          # bootstrap vector size; ignored in endpoint mode

[context]
budget_tokens = 4096

[self_model]
# How often (in turns) Mimir re-synthesizes its always-on self-model from its own operational
# history (knowledge-store stats + recent reflections). 0 disables it (seed identity only).
refresh_every = 5

[working_memory]
# Rolling compression: once `fold_threshold` raw exchanges accumulate, fold the OLDEST into the
# rolling summary (the previous summary folded in too, compressed harder the further back) and keep
# the most recent `keep_recent` verbatim. Runs off the hot path in the burst worker after the reply.
fold_threshold = 10   # 0 disables compression (recency-only working memory)
keep_recent = 4

[entity_graph]
# Connected-knowledge retrieval: how many hops to traverse from the entities named in a turn,
# and the max connected facts to inject. hops = 0 disables retrieval (triples are still stored).
hops = 2
max_facts = 8

[sleep]
# The sleep cycle: heavy maintenance (dedup, salience/confidence decay, archival of stale
# provisionals, contradiction resolution) + temporal-narrative roll-ups. With streaming chat on a
# slow machine the post-turn burst window is too short, so this runs in its own wall-clock window
# when nobody's around. A daemon checks the clock; inside the window (and not already done today,
# not mid-turn) it runs the phases in order, skipping any that won't fit the time left, resuming a
# same-night restart, with catch-up before noon if the window was missed. "Run sleep now" any time.
enabled = true               # the window scheduler (recommended on); false = manual / turn-cadence only
window_start = "02:00"       # local HH:MM the window opens
window_end = "06:00"         # local HH:MM it closes (may cross midnight, e.g. start 23:00, end 06:00)
check_interval_s = 900       # how often the daemon checks the clock (15 min)
# Legacy turn-cadence path (superseded by the window above). 0 = off; N = also consolidate every N
# turns off the hot path. Left for back-compat / headless setups without a steady clock.
every = 0

[deliberation]
# During the sleep cycle, the system surfaces its OWN conflicts — graph tensions (a subject with two
# values under a non-functional relation) and divergent near-duplicate memories — and submits the few
# most worth arguing to the inner council for adversarial reasoning, storing the verdicts. The council
# is otherwise only invoked by hand; this makes it self-directed. Also a "Deliberate now" manual button.
enabled = true
limit = 3                    # max conflicts argued per cycle (each is several model calls)

[server]
# Reference web server / integration API (see docs/API.md). Auth is off by default (open localhost).
# Set a token to require `Authorization: Bearer <token>` on every /api/* route — or use the env var
# MIMIR_API_TOKEN, which overrides this (keeps secrets out of the file).
# api_token = "a-long-random-string"
# cors_origins = ["https://my-avatar.local"]   # browser origins allowed to call the API; ["*"] = any

[self_knowledge]
# Bake a doc describing what the system is and how it works into memory in the nightly cycle, so it
# can answer about itself. Content-hashed (re-embeds only on change). Empty/unset disables it.
doc = "README.md"

[diagnostics]
# Self-observability (DESIGN §10): the system surfaces its own recent errors into the turn's context
# ("I've had an error") and digests them in the nightly cycle's health phase. Fail-loud + fail-aware.
surface_errors = true
error_context_window_s = 1800   # an error this recent (s) shows in context; older ones fade out
error_context_max = 5

[procedural]
# Learned reasoning habits (trigger → procedure). When a turn matches a habit's trigger, the
# procedure is injected as guidance. Teach habits via brain.learn_procedure() or the web UI.
top_k = 3            # max matching habits injected per turn
min_match = 0.3      # minimum trigger relevance (cosine or keyword) before a habit fires

[locale]
# Temporal grounding: the clock/calendar sense injected each turn so Mimir can reason about time
# (and answer "what season is it?" with no model call). Universal — no place is baked into core.
# timezone = "America/Vancouver"   # IANA name; omit to use the host's local zone
hemisphere = "north"               # "north" or "south" — which way the seasons run

# [wiki] turns on an OPTIONAL offline encyclopedia as a live reference layer — zero Python deps.
# You run `kiwix-serve` (a single static binary, no install) over any ZIM you downloaded, and Mimir
# queries it over stdlib HTTP, like any other local endpoint. Pick your ZIM size: Wikipedia "nopic"
# (recommended), a medical wiki, a top-50k slice, etc. Each turn's query is searched live and the
# top articles are injected as an attributed reference section. Omit the block to disable.
# [wiki]
# url = "http://localhost:8080"   # the kiwix-serve base URL
# book = "wikipedia"              # the ZIM's book name as kiwix-serve lists it
# max_articles = 2               # top hits injected per turn
# max_chars = 800                # chars of lead text per article
# timeout_s = 2.0                # hard cap so a slow/missing wiki never stalls a turn

[provider]
# "ollama" talks to a local Ollama server with stdlib HTTP (no extra deps).
# "mock" is a deterministic, offline stand-in for tests/demos (needs no model server).
type = "ollama"
host = "http://localhost:11434"

# [backend] turns on the DISTRIBUTED fleet: pool several machines that each just run `ollama serve`
# (zero setup on them). Requests route only to a node that has the model. Great for running the
# brain on a small box (even a Raspberry Pi) and borrowing GPUs over the LAN. Omit for single-host.
# [backend]
# lan_backend = true               # scan the LAN for Ollama nodes
# subnet = "192.168.1.0/24"         # CIDR to scan; omit to auto-detect the local /24
# nodes = ["192.168.1.50:11434"]    # optional explicit nodes (always included)
# refresh_interval_s = 60           # active health/inventory refresh; 0 disables the prober
# idle_probe_interval_s = 1800      # live speed is learned passively from real calls; this rare idle
#                                   # heartbeat (default 30 min, 0 = off) tops up nodes gone quiet.
#                                   # Routing picks the healthiest, fastest node (latency × load).
# latency_alpha = 0.3               # EWMA weight on the newest latency sample (higher tracks faster)
# max_model_size_b = 30             # only YOU know your hardware: benchmark/route up to this many B
# min_model_size_b = 0              # ...and a floor (0 = off): don't let a tiny model that scores
#                                   # 'high enough' + wins on latency beat a bigger, better one
# max_latency_s = 0                 # per-turn latency target in seconds; 0 = off
# benchmark_num_ctx = 24576         # OPERATIONAL context window — qualify at the size you deploy at.
#                                   # Ollama defaults to a tiny 2048 (which truncates the layered
#                                   # epistemic prompts); the long-context probe SCALES with this, so
#                                   # it tests the window you'll actually run. 24576 (24k) is a proven
#                                   # window for a RAG + compression system — a fraction of models'
#                                   # 128k–256k max, which you neither need nor want (KV-cache cost +
#                                   # "lost in the middle"). Continuity is curated RAG, not raw window.
#                                   # Must match your production num_ctx or the warm KV cache rebuilds.

# --- roles: one model per cognitive job. `model` is required; other keys are tuned params. ---

[roles.chat]
model = "llama3.1:8b"
temperature = 0.7
num_ctx = 8192

[roles.bake]
model = "llama3.1:8b"
temperature = 0.0      # faithful extraction; no creativity

[roles.reasoning]
model = "llama3.1:8b"
temperature = 0.3

[roles.embed]
# Required only when [embeddings] mode = "endpoint".
model = "nomic-embed-text"

# [roles.council] is OPTIONAL. The inner council auto-discovers the models actually installed and
# spreads its personas across them; this entry only sets the fallback model + tuned params (e.g. a
# higher temperature for more persona diversity) used when discovery finds nothing.
# [roles.council]
# model = "llama3.1:8b"
# temperature = 0.8
